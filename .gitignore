# Unreal Engine 5.5+ — generated/intermediate content (never commit these)
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
ArchivedBuilds/

# Exception: hand-written source files that UE convention puts under Build/.
# Re-includes require un-excluding the parent dirs first, then re-excluding
# the generated children, then re-including the source.
!SiteSyncAR/Build/
SiteSyncAR/Build/*
!SiteSyncAR/Build/IOS/
SiteSyncAR/Build/IOS/*
!SiteSyncAR/Build/IOS/SiteSyncAR_IOS_UPL.xml
# App icon source — must be tracked so PC builds use the SiteIQ icon, not the
# default Unreal logo. UE 5.6 modern-Xcode builds compile the icon from an
# Assets.xcassets/AppIcon.appiconset via actool (--app-icon AppIcon); the
# legacy Graphics/Icon*.png path is IGNORED by that build (see decisions.md 2026-06-01).
!SiteSyncAR/Build/IOS/Resources/
SiteSyncAR/Build/IOS/Resources/*
!SiteSyncAR/Build/IOS/Resources/Graphics/
!SiteSyncAR/Build/IOS/Resources/Graphics/*.png
!SiteSyncAR/Build/IOS/Resources/Assets.xcassets/
!SiteSyncAR/Build/IOS/Resources/Assets.xcassets/**

# IDE artifacts
.vs/
.vscode/
.idea/

# Xcode / macOS artifacts
*.xcworkspace/
*.xcodeproj/
xcuserdata/
*.dSYM/

# Visual Studio artifacts
*.sln
*.suo
*.user
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb
*.ncb
*.aps

# UE build outputs
*.pdb
*.exp
*.lib
*.ilk
*.map

# Packaging output
Releases/

# Python (MCP server / UE Python scripts)
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.env

# UnrealMCP runtime artifacts
SiteSyncAR/Plugins/UnrealMCP/Python/unreal_mcp.log
SiteSyncAR/Plugins/UnrealMCP/Python/__pycache__/
*.egg-info/

# Repo-root .claude/: track skills + commands, ignore everything else (per-machine settings)
.claude/*
!.claude/skills/
!.claude/commands/
# Re-include the `build` skill (its dir name collides with UE's Build/ ignore)
!.claude/skills/build/
# Per-machine Claude Code state inside the UE project subdir — never commit
SiteSyncAR/.claude/

# OS
.DS_Store
Thumbs.db

# iOS app-container / device-pull artifacts (never commit — pulled
# from the device with `xcrun devicectl ... pull` and only useful for
# one-off debugging). Validation `.log` files in `logs/` are kept.
logs/device-pull*/
logs/dev-pull*/
**/Library/Caches/
**/Library/Preferences/*.plist
**/Library/SavedApplicationState/
**/Library/SplashBoard/
**/Library/Cookies/
*.ktx
*.dyld4
*.mdb

# Keep these tracked
!Source/
!Config/
!Content/
!Plugins/
!*.uproject
